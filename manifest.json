{
  "manifest_version": 3,
  "name": "Asaki",
  "version": "1.0.0",
  "description": "Highlight any text and instantly compare answers from every major AI model — with a synthesized consensus.",
  "permissions": ["contextMenus", "activeTab", "storage", "sidePanel", "scripting"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.x.ai/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": { "default_path": "src/panel/index.html" },
  "options_ui": { "page": "src/options/index.html", "open_in_tab": true },
  "action": {
    "default_title": "Open Asaki",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "trigger-asaki": {
      "suggested_key": { "default": "Ctrl+Shift+K", "mac": "Command+Shift+K" },
      "description": "Ask AI about selected text"
    }
  }
}
